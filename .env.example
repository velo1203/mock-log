# Google Sheets CSV 공개 URL
# Google Sheets → 파일 → 공유 → 웹에 게시 → CSV 형식으로 게시 후 URL 입력
VITE_CSV_URL=https://docs.google.com/spreadsheets/d/e/YOUR_SHEET_ID/pub?output=csv

# 학습 후기 CSV URL (컬럼: title, date, category, rating, review)
VITE_REVIEW_CSV_URL=https://docs.google.com/spreadsheets/d/e/YOUR_REVIEW_SHEET_ID/pub?output=csv
